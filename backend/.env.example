# Backend Environment Variables
# Used for local development and as a reference for production deployment (AWS Lambda console)

# AWS Configuration
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
DYNAMODB_TABLE_NAME=gujcet-platform

# OTP (Twilio)
# Create a free trial at Twilio.com to get these
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Email (AWS SES)
# Sender address must be verified in the AWS SES console
SES_SENDER_EMAIL=noreply@yourdomain.com

# Authentication (JWT & Cookies)
# Set JWT_SECRET_KEY to a strong random string in production
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
ADMIN_JWT_EXPIRY_HOURS=8

# Cookie Security
# Use "none" if frontend and backend are on different domains (e.g., Netlify + AWS)
# Must be "lax" or "strict" if on same domain
COOKIE_SAMESITE=none

# Admin Account
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$12$...your-bcrypt-hash...

# Application Configuration
# FRONTEND_URL is used for CORS and should match your Netlify URL in production
FRONTEND_URL=http://localhost:5173
FRONTEND_CUSTOM_URL=https://your-site.netlify.app
ENVIRONMENT=development
