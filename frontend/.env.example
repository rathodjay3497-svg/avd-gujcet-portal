# Backend API URL (Use your AWS API Gateway URL in production)
VITE_API_BASE_URL=http://localhost:8000

# Google OAuth
# Must match the client ID used in the backend GOOGLE_CLIENT_ID variable
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Application Identity
VITE_APP_NAME=GUJCET Free Counseling
VITE_CONTACT_EMAIL=support@yourdomain.com
